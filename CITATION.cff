title: "ChildClimate Risk Atlas"
message: "If you use this software or its outputs, please cite as below."
type: software
authors:
  - given-names: Victoria
    family-names: "(project lead)"
    affiliation: "Trameter Nigeria Ltd"
repository-code: "https://github.com/Trameter/childclimate-atlas"
